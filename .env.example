# Supabase (필수 - 프로덕션용)
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# 로컬 개발용 (프로덕션/Vercel에는 절대 설정하지 말 것)
# NEXT_PUBLIC_SKIP_CUSTOMER_AUTH=true  # 로컬: 고객 로그인 생략, 관리자 비밀번호만 필요 (데모 없음)
# NEXT_PUBLIC_SKIP_SUPABASE=1         # Supabase 비활성화 시 localStorage만 사용

# 지도 기반 거리 계산 (하나라도 설정 시 지도 API 사용, 없으면 주소 추정)
# Kakao: https://developers.kakao.com/ → 앱 생성 → REST API 키
# KAKAO_REST_API_KEY=your_kakao_rest_api_key
# Naver: https://console.ncloud.com/ → Maps Geocoding
# NAVER_MAPS_CLIENT_ID=your_naver_client_id
# NAVER_MAPS_CLIENT_SECRET=your_naver_client_secret
# Google: https://console.cloud.google.com/ → Geocoding API 활성화
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# 예약확정 SMS 발송 (알리고): https://smartsms.aligo.in/
# ALIGO_USER_ID=your_aligo_user_id
# ALIGO_API_KEY=your_aligo_api_key
# ALIGO_SENDER=발신번호
# ALIGO_TESTMODE=Y  # 연동 테스트 시 (실제 발송 없음)
# SKIP_SMS_SEND=1   # 개발 시 SMS 발송 생략 (테스트용)
