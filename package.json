{
  "name": "mimi-salon-pet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env CHOKIDAR_USEPOLLING=true WATCHPACK_POLLING=true node --max-old-space-size=4096 node_modules/next/dist/bin/next dev -p 5006",
    "dev:restart": "npx --yes kill-port 5006 2>nul & npm run dev",
    "dev:fresh": "npm run clean && npx --yes kill-port 5006 2>nul & npm run dev",
    "build": "next build",
    "start": "next start -p 5006",
    "lint": "next lint",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\"",
    "setup:supabase": "node scripts/setup-supabase.js",
    "setup:supabase:full": "node scripts/setup-supabase-full.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
