{
  "name": "mimi-salon-pet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env CHOKIDAR_USEPOLLING=true WATCHPACK_POLLING=true node --max-old-space-size=4096 node_modules/next/dist/bin/next dev -p 5006",
    "dev:auto": "npx concurrently -n dev,push -c blue,yellow \"npm run dev\" \"npm run watch:push\"",
    "dev:restart": "node -e \"try{require('child_process').execSync('npx --yes kill-port 5006',{stdio:'inherit'})}catch(e){}\" && npm run dev",
    "dev:fresh": "npm run clean && node -e \"try{require('child_process').execSync('npx --yes kill-port 5006',{stdio:'inherit'})}catch(e){}\" && npm run dev",
    "build": "next build",
    "deploy": "npm run build && npx vercel --prod --yes --force --scope koobg9-ms-projects",
    "deploy:force": "npm run clean && npm run build && npx vercel --prod --yes --force --scope koobg9-ms-projects",
    "start": "next start -p 5006",
    "lint": "next lint",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\"",
    "setup:supabase": "node scripts/setup-supabase.js",
    "setup:supabase:full": "node scripts/setup-supabase-full.js",
    "vercel:remove-old": "node scripts/vercel-remove-old.js",
    "logo:transparent": "node scripts/remove-logo-bg.js",
    "push": "node scripts/auto-push.js",
    "watch:push": "node scripts/auto-push.js --watch",
    "sync": "node scripts/auto-push.js && npm run deploy"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.99.2",
    "next": "14.2.35",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "glob": "^10.4.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
